// Author: Fitz Ramirez
// Sits between the routes in app.js and the model queries
// Each function matches one route: receive request → call model → send response

// pull in the model so we can call its query functions
const orderController = require('../models/orderModel');

module.exports = {

  // getProcessPage: handles GET /process-orders
  // fetches all sanctioned quotes and renders the EJS view with them
  // the EJS template loops over the quotes array to build the table rows
  getProcessPage: (req, res) => {
    orderModel.getSanctionedQuotes((quotes) => {
      // res.render sends process.ejs to the browser
      // the second argument { quotes } makes the array available inside the EJS as 'quotes'
      res.render('process', { quotes });
    });
  },

  // getQuoteDetails: handles GET /process-orders/:id
  // called by the openModal() JS function in process.ejs via fetch
  // returns JSON (not a rendered page) because the modal fills itself in via JS
  getQuoteDetails: (req, res) => {
    // req.params.id pulls the :id out of the URL, e.g. /process-orders/42 → id = 42
    const id = req.params.id;

    // first get the main quote row
    orderModel.getQuoteById(id, (quote) => {
      // if nothing came back, return a 404 so the frontend can handle it
      if (!quote) return res.status(404).json({ error: 'Quote not found' });

      // then get the line items for this quote
      orderModel.getLineItems(id, (lineItems) => {

        // then get the secret notes for this quote
        orderModel.getNotes(id, (notes) => {

          // send all three back as one JSON object
          // the fetch in process.ejs receives this as data.quote, data.lineItems, data.notes
          res.json({ quote, lineItems, notes });
        });
      });
    });
  },

  // processOrder: handles POST /process-orders/process
  // triggered by the Process PO button in the modal
  // this is the main action — calls external system, then writes to 3 tables
  processOrder: (req, res) => {
    // quoteId comes from the fetch body in processPO() in process.ejs
    const { quoteId } = req.body;

    // fetch the quote first so we have final_total and associate_id for later steps
    orderModel.getQuoteById(quoteId, (quote) => {

      // make sure the quote exists and is still sanctioned
      // prevents processing the same quote twice if someone clicks the button again
      if (!quote || quote.quote_status !== 'sanctioned') {
        return res.status(400).json({ error: 'Quote not found or not sanctioned' });
      }

      // call the external processing system with the order details
      // replace this URL later
      fetch('https://blitz.cs.niu.edu/PurchaseOrder/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        // send the quote id, total amount, and associate so the external system can log it
        body: JSON.stringify({
          quote_id:     quote.id,
          amount:       quote.final_total,
          associate_id: quote.associate_id
        })
      })
      .then(r => r.json())
      .then(external => {
        // external system sends back processingDate and commissionRate
        const { processingDate, commissionRate } = external;

        // compute the actual dollar commission from the rate
        // e.g. $450 total * 0.05 rate = $22.50 commission
        const commissionTotal = parseFloat(quote.final_total) * parseFloat(commissionRate);

        // step 1 of 3: update the quote row with status, commission, and processing date
        orderModel.markOrdered(quoteId, commissionRate, commissionTotal, processingDate, (err) => {
          if (err) return res.status(500).json({ error: 'Failed to update quote' });

          // step 2 of 3: add the commission to the salesperson's running total
          orderModel.addCommissionToAssociate(quote.associate_id, commissionTotal, (err) => {
            if (err) return res.status(500).json({ error: 'Failed to update commission' });

            // step 3 of 3: insert a record into orderdb as the permanent order receipt
            orderModel.insertOrder(
              quoteId,
              quote.final_total,
              quote.discount_final,
              commissionRate,
              commissionTotal,
              (err) => {
                if (err) return res.status(500).json({ error: 'Failed to insert order' });

                // all three writes succeeded — send processingDate back to the browser
                // the alert in processPO() in process.ejs displays it to the user
                res.json({ success: true, processingDate });
              }
            );
          });
        });
      })
      // if the external system call itself fails (network error, timeout, etc.)
      .catch(err => {
        res.status(500).json({ error: 'External system failed: ' + err.message });
      });
    });
  }

};