<!--Fitz Ramirez-->
<!DOCTYPE html>
<html>
  <head>
    <title>Processing Orders</title>
  </head>
  <body>
    <a href="/sanction">Sanction Quotes</a>
    <!--will be on the actual page-->
    <div class="content">
      <h1>List of sanctioned quotes:</h1>
        <table id="quotes-table">
          <tbody id="quotes-body">
            <!-- javascript does rows -->
          </tbody>
        </table>
      <!--add the x quotes found shit here-->
      <p id="quote-count"></p>
    </div>

    <!--modal overlay, starts off invisible-->
    <div id="modal-overlay" style="display:none"> 
      <div id="modal">
        <button id="modal-close" onclick="closeModal()">X</button>

        <h2 id="modal-title"></h2>
        <p id="modal-address"></p>
        <p id="modal-website"></p>
        <p>Email: <input type="text" id="modal-email" readonly></p>

        <h3>LINE ITEMS:</h3>
        <table id="modal-items">
          <tbody id="modalItemsBody"></tbody>
        </table>

        <h3>SECRET NOTES:</h3>
        <div id="modal-notes"></div>

        <p>
          Discount: <span id="modal-discount"></span>
        </p>
        <p><strong>Amount: <span id="modal-amount"></span></strong></p>
        <hr>
        <p>
          click here to process the quote into an order:
          <button id="process-btn" onclick="processPO()">Process PO</button>
        </p>
      </div>
    </div>
    
  </body>
</html>
