<%- include('../partials/header') %>
<main>
    <h2>My Quotes</h2>
    <a href="/associate/quotes/new"> + New Quote </a>

    <& if(typeof success !== 'undefined' && success) { %>
        <p style="color:green;"><%= success %></p>
    <% } %>

    <% if (quotes.length === 0) { %>
        <p>No quotes, create one to test</p>
    <% } else { %>
        <table border="1" cellpadding="6" cellspacing="0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Subtotal</th>
                    <th>Total</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% quotes.forEach(function(quote)) { %>
                    <tr>
                        <td><%= quote.id %></td>
                    </tr>
            </tbody>
        </table>

</main>
